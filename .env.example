# 16, 24, or 32 bytes. A 32-character ASCII secret is a good default.
LANGGRAPH_AES_KEY=replace-with-32-byte-secret-key

# Optional project-local database path for encrypted LangGraph checkpoints.
FAMILY_CHAT_DB_PATH=data/family_chat_memory.sqlite3

# Optional family member ids known to this install.
FAMILY_CHAT_MEMBERS=son,parent-a,parent-b

# Fixed member identity for this device.
FAMILY_CHAT_DEVICE_MEMBER=son

# Optional adult unlock PIN. If left blank, the adult profile stays disabled.
FAMILY_CHAT_ADMIN_PIN=

# Optional: require the same adult PIN before pulling new models.
FAMILY_CHAT_MODEL_PULL_REQUIRES_PIN=

# Default is local-only. Set to 0.0.0.0 only if you intentionally want LAN access.
# FAMILY_CHAT_HOST=127.0.0.1

# Optional quick demo mode when Ollama is not running.
# FAMILY_CHAT_MOCK_OLLAMA=1
